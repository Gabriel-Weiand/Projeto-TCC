# ═══════════════════════════════════════════════════════════════
# API — Laboratório (AdonisJS)
# ═══════════════════════════════════════════════════════════════
#   cp .env.example .env
#   node ace generate:key   # preenche APP_KEY
#
#   Fuso do laboratório (calendário, limites de reserva, "hoje" no dashboard):
#   Use o fuso onde as máquinas ficam (ex.: laboratório em Pelotas).
#   Liste fusos: timedatectl list-timezones
TZ=America/Sao_Paulo

PORT=7372
HOST=0.0.0.0
LOG_LEVEL=info
APP_KEY=
NODE_ENV=production
DB_CONNECTION=sqlite

# ── Seed (perfis: dev | minimal | lab) ─────────────────────────
#   node ace seed:fresh dev       — recomendado (equivale a migration:fresh --seed + perfil)
#   npm run seed:dev | seed:minimal | seed:lab
#   LAB_SEED_PROFILE=lab node ace migration:fresh --seed
#   NÃO use "node ace migration:fresh dev" — o "dev" é ignorado e o seed não roda.
# LAB_SEED_PROFILE=dev
# LAB_SEED_ADMIN_EMAIL=admin@lab.ufpel.edu.br
# LAB_SEED_ADMIN_PASSWORD=admin123
# LAB_SEED_GACIG1_TOKEN=   # token fixo do agente na GaciG1 (perfil lab)

# ── Autenticação web (tokens de usuário) ───────────────────────
# Formato aceito pelo Adonis access tokens: "6 hours", "1 day", "30 days"
LAB_AUTH_TOKEN_EXPIRES_IN=3 hours

# ── Calendário (dashboard) ─────────────────────────────────────
# Passado fixo (dias antes de "hoje" no fuso TZ)
LAB_CALENDAR_PAST_DAYS=30
# Opções de extensão futura no seletor do front (dias, separados por vírgula)
LAB_CALENDAR_FUTURE_DAYS_OPTIONS=90,180,365
# Valor inicial do seletor (deve estar em FUTURE_DAYS_OPTIONS)
LAB_CALENDAR_DEFAULT_FUTURE_DAYS=90

# ── Reservas (alocações) ───────────────────────────────────────
# Nomes no calendário: true = todos veem quem reservou; false = só admin
LAB_ALLOCATION_PUBLIC_NAMES=false
# Data de término máxima: hoje + N dias (fuso TZ)
LAB_ALLOCATION_MAX_FUTURE_DAYS=365
LAB_ALLOCATION_MIN_DURATION_MINUTES=15
# Grace pós-endTime (bash + estender) e intervalo mínimo entre reservas; 0 = desativado
LAB_ALLOCATION_GRACE_MINUTES=10
# SFTP com chave após fim (+ grace se reserva natural); 0 = desativado
LAB_ALLOCATION_POST_SFTP_MINUTES=1440
# Dias após endTime até userdel no SO (drift)
LAB_ALLOCATION_DELETE_USER_DAYS=7
# true = toda reserva de usuário nasce pending (admin aprova); false = approved direto
LAB_ALLOCATION_REQUIRE_ADMIN_APPROVAL=false
# Faixa horária local opcional (0–24); 0 e 24 = dia inteiro
LAB_SCHEDULE_START_HOUR=0
LAB_SCHEDULE_END_HOUR=24

# ── Telemetria global (perfis fast / eco para todas as máquinas) ─
# Opcional: JSON parcial sobrescreve defaults (persistência admin: storage/lab/telemetry_presets.json)
# LAB_TELEMETRY_FAST={"intervalSeconds":30,"batchSize":4,"telemetrySet":{"cpu":true,"gpu":true}}
# LAB_TELEMETRY_ECO={"intervalSeconds":60,"batchSize":15,"telemetrySet":{"cpu":true,"gpu":false}}

# ── Manutenção (retenção e resumo) ─────────────────────────────
# Horas após endTime para gerar resumo TWA (allocation_metrics)
LAB_SUMMARIZE_AFTER_HOURS=168
# Retenção (dias desde endTime da alocação ou createdAt da entidade)
LAB_PRUNE_ALLOCATION_DAYS=30
LAB_PRUNE_NOTIFICATION_DAYS=30
LAB_PRUNE_SSH_ATTEMPTS_DAYS=30

# ── Schedulers (expressão cron) ────────────────────────────────
# ┌───────────── minuto (0 - 59)
# │ ┌─────────── hora (0 - 23)
# │ │ ┌───────── dia do mês (1 - 31)
# │ │ │ ┌─────── mês (1 - 12 ou JAN-DEC)
# │ │ │ │ ┌───── dia da semana (0 - 6 ou SUN-SAT)
# │ │ │ │ │
# * * * * * - notação cron: */5 = a cada 5 min; 0 */4 = a cada 4 h (minuto 0)
# Manutenção sistemática (a cada 4 h): tokens, resumo, prune de alocações/notificações/SSH
LAB_SCHEDULER_MAINTENANCE_CRON=0 */4 * * *
# Finalização automática de alocações vencidas + lembretes/notificações
LAB_SCHEDULER_AUTO_FINALIZE_CRON=*/5 * * * *

# ── Notificações ───────────────────────────────────────────────
# Lembrete de reserva (minutos antes do início)
LAB_NOTIF_UPCOMING_MINUTES=10
# Revalidação de chave SSH (minutos antes do início e no início via scheduler/heartbeat)
LAB_NOTIF_SSH_KEY_MINUTES=5
# Flood SSH: janela, limiar de falhas e cooldown entre alertas admin (horas)
LAB_NOTIF_SSH_FLOOD_WINDOW_MINUTES=15
LAB_NOTIF_SSH_FLOOD_THRESHOLD=20
LAB_NOTIF_SSH_FLOOD_COOLDOWN_HOURS=1
# Agente sem heartbeat: minutos sem lastSeenAt e cooldown entre alertas admin (horas)
# O scheduler roda a cada 5 min; o cooldown limita a 1 aviso/dia por máquina (sinal para manutenção/definir como desativada)
LAB_NOTIF_AGENT_OFFLINE_MINUTES=10
LAB_NOTIF_AGENT_OFFLINE_COOLDOWN_HOURS=24
