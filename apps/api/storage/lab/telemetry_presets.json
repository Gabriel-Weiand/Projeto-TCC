{
  "fast": {
    "intervalSeconds": 25,
    "batchSize": 6,
    "telemetrySet": {
      "cpu": true,
      "gpu": true,
      "ramAndSwap": true,
      "disk": true,
      "networkIO": true,
      "temperatures": true,
      "activeUsers": true,
      "processCapture": true
    },
    "processCaptureConfig": {
      "compareMetric": "cpuPercent",
      "topX": 10,
      "userScope": "all"
    }
  },
  "eco": {
    "intervalSeconds": 90,
    "batchSize": 15,
    "telemetrySet": {
      "cpu": true,
      "gpu": true,
      "ramAndSwap": true,
      "disk": false,
      "networkIO": false,
      "temperatures": true,
      "activeUsers": true,
      "processCapture": false
    },
    "processCaptureConfig": {
      "compareMetric": "cpuPercent",
      "topX": 10,
      "userScope": "all"
    }
  }
}