{
  "fast": {
    "intervalSeconds": 25,
    "batchSize": 6,
    "telemetrySet": {
      "cpu": true,
      "gpu": true,
      "ramAndSwap": true,
      "diskSpace": true,
      "diskIO": true,
      "networkIO": true,
      "temperatures": true,
      "activeUsers": true
    }
  },
  "eco": {
    "intervalSeconds": 90,
    "batchSize": 15,
    "telemetrySet": {
      "cpu": true,
      "gpu": false,
      "ramAndSwap": true,
      "diskSpace": true,
      "diskIO": false,
      "networkIO": false,
      "temperatures": false,
      "activeUsers": true
    }
  }
}