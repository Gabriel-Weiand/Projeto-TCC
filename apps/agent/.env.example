# ╔══════════════════════════════════════════════════════════════╗
# ║   Agente de Monitoramento — Configuração                    ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Copie este arquivo para .env e preencha com os dados da sua máquina:
#   cp .env.example .env
#   nano .env

# ═══════════════════════════════════════════════════════════════
# 🌐 REDE — IP do servidor API (backend AdonisJS)
# ═══════════════════════════════════════════════════════════════
#
#   Formato: http://<IP-DO-SERVIDOR>:<PORTA>
#
#   Exemplos:
#     Rede local:   http://192.168.1.100:3333
#     Mesma máquina: http://localhost:3333
#
#   Para descobrir o IP do servidor, execute no terminal do servidor:
#      hostname -I | awk '{print $1}'
#
SERVER_URL=http://192.168.1.100:3333

# ═══════════════════════════════════════════════════════════════
# 🔑 TOKEN DA MÁQUINA
# ═══════════════════════════════════════════════════════════════
#
#   O token é gerado quando um admin cadastra esta máquina na API:
#     POST /api/v1/machines  (via painel admin ou seed)
#
#   ⚠️  O token é exibido APENAS UMA VEZ na criação.
#       Se perder, o admin pode regenerar:
#         POST /api/v1/machines/:id/regenerate-token
#
#   Se usou o seed, o token é exibido no console ao rodar:
#     cd apps/api && node ace db:seed
#
MACHINE_TOKEN=cole_aqui_o_token_da_maquina

# ═══════════════════════════════════════════════════════════════
# 🖥️ MAC ADDRESS (endereço físico da placa de rede)
# ═══════════════════════════════════════════════════════════════
#
#   Deixe VAZIO para auto-detectar (recomendado).
#   Defina manualmente apenas se a auto-detecção falhar.
#
#   Formato: AA:BB:CC:DD:EE:FF
#
#   Para ver o MAC da sua máquina:
#     ip link show | grep ether
#
#   Para desenvolvimento local com seed:
#     MAC_ADDRESS=AA:BB:CC:DD:01:01   (MAC do PC-LAB-01 no seed)
#
MAC_ADDRESS=

# ═══════════════════════════════════════════════════════════════
# ⏱️ INTERVALOS (segundos)
# ═══════════════════════════════════════════════════════════════
#
#   HEARTBEAT_INTERVAL: Frequência do polling de estado (padrão: 30s)
#   TELEMETRY_INTERVAL: Frequência de envio de métricas (padrão: 5s)
#
HEARTBEAT_INTERVAL=30
TELEMETRY_INTERVAL=5
