# ============================================
# Configuração do Agente de Monitoramento
# ============================================

# URL do servidor da API (sem barra no final)
SERVER_URL=http://192.168.1.100:3333

# Token de autenticação da máquina (gerado ao cadastrar a máquina na API)
MACHINE_TOKEN=cole_aqui_o_token_da_maquina

# Endereço MAC da máquina (opcional - auto-detectado se vazio)
# Formato: AA:BB:CC:DD:EE:FF
MAC_ADDRESS=

# Intervalos de comunicação (em segundos)
HEARTBEAT_INTERVAL=30
TELEMETRY_INTERVAL=5
