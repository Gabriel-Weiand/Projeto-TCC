# Configuração do Agente de Servidor

# URL do servidor API
SERVER_URL=http://localhost:3333

# Token da máquina (gerado pelo admin no painel web)
MACHINE_TOKEN=

# MAC Address (auto-detectado se não configurado)
# MAC_ADDRESS=AA:BB:CC:DD:EE:FF

# Intervalos em segundos
HEARTBEAT_INTERVAL=30
TELEMETRY_INTERVAL=5
SSH_POLL_INTERVAL=5

# Pesos cgroups v2
CGROUP_OWNER_CPU_WEIGHT=1000
CGROUP_GUEST_CPU_WEIGHT=10
CGROUP_DEFAULT_CPU_WEIGHT=100

# Usuários do sistema disponíveis para alocação (separados por vírgula)
# SYSTEM_USERS=render01,render02,render03
